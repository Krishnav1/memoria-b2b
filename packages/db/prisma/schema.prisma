// This is your Prisma schema file,
// learn more about it in our docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Studios (photographer businesses)
model Studio {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  invitations Invitation[]

  @@index([slug])
}

// Users (belong to studios)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  role      UserRole @default(MEMBER)

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email])
  @@index([studioId])
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

// Invitations (pending user invitations)
model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      UserRole @default(MEMBER)
  token     String   @unique @default(cuid())

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([studioId])
}
