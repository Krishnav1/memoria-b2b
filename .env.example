# Database (Prisma + PostgreSQL)
# Works with any PostgreSQL provider: Supabase, Railway, Neon, etc.
DATABASE_URL="postgresql://user:password@localhost:5432/memoria_b2b"

# Supabase (for Auth, Storage, Edge Functions - optional)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2 (for file storage - later)
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=memoria-photos

# App URLs
NEXT_PUBLIC_STUDIO_URL=http://localhost:3000
NEXT_PUBLIC_PWA_URL=http://localhost:3001