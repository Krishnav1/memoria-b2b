{
  "name": "memoria-b2b",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "pnpm --filter @memoria/db db:migrate",
    "db:push": "pnpm --filter @memoria/db db:push",
    "db:studio": "pnpm --filter @memoria/db db:studio",
    "db:generate": "pnpm --filter @memoria/db db:generate"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^2.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}